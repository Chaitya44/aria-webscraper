rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow user to read/write their own root document (daily counts)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Allow user to read/write their own subcollections (history)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
