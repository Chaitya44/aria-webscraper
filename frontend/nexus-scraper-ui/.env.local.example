# Aria — Frontend Environment Variables
# Copy this file to .env.local and fill in your values.

# ── Backend API ──────────────────────────────────────────────────────────────
# Leave empty for local dev (defaults to http://localhost:8000).
# Set to your Render/Railway URL for production.
# NEXT_PUBLIC_API_URL=https://aria-backend.onrender.com

# ── Firebase Config ──────────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your Apps → Web App
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ── BYOK — Gemini API Key ────────────────────────────────────────────────────
# The Gemini key is NOT stored here. It is entered by each user at login
# and stored only in their browser's localStorage under "aria_gemini_key".
# The backend never holds a Gemini key server-side — this is the BYOK model.
#
# The Firecrawl key is a SERVER-SIDE secret stored in backend/.env only.
# Never add FIRECRAWL_API_KEY here — it must never reach the browser.
