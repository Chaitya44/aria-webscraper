# ═══════════════════════════════════════════════════
# Aria WebScraper — .gitignore
# ═══════════════════════════════════════════════════

# ── Environment & Secrets ─────────────────────────
.env
.env.local
.env*.local

# ── Python ────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
venv/
.venv/
env/

# ── Node.js ───────────────────────────────────────
node_modules/
.next/
out/
build/
.vercel/
*.tsbuildinfo
next-env.d.ts

# ── OS & IDE ──────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
.opencode/

# ── Data & Logs ───────────────────────────────────
*.db
*.sqlite3
*.csv
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build Artifacts ───────────────────────────────
*.pem
/coverage